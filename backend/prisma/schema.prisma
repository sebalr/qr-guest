generator client {
  provider                = "prisma-client"
  output                  = "../src/generated/prisma"
  moduleFormat            = "cjs"
  generatedFileExtension  = "ts"
  importFileExtension     = ""
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                String               @id @default(uuid())
  name              String
  plan              String               @default("free")
  createdAt         DateTime             @default(now()) @map("created_at")
  userTenants       UserTenant[]
  events            Event[]
  tickets           Ticket[]
  scans             Scan[]
  guests            Guest[]
  ticketTypes       TicketType[]
  temporaryScanners TemporaryScanner[]
  syncStates        SyncState[]
  deviceDebugEvents DeviceEventDebugData[]

  @@map("tenants")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String?       @map("password_hash")
  emailVerifiedAt DateTime?  @map("email_verified_at")
  isSuperAdmin Boolean       @default(false) @map("is_super_admin")
  createdAt    DateTime      @default(now()) @map("created_at")
  userTenants  UserTenant[]
  scans        Scan[]
  temporaryScannerProfiles TemporaryScanner[] @relation("TemporaryScannerUser")
  createdTemporaryScanners TemporaryScanner[] @relation("TemporaryScannerCreatedBy")
  authTokens   UserAuthToken[]

  @@map("users")
}

model UserAuthToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  tokenHash  String   @unique @map("token_hash")
  type       String
  expiresAt  DateTime @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, consumedAt])
  @@map("user_auth_tokens")
}

model UserTenant {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  role      String   @default("member")
  joinedAt  DateTime @default(now()) @map("joined_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("user_tenants")
}

model Event {
  id          String                 @id @default(uuid())
  tenantId    String                 @map("tenant_id")
  name        String
  description String?
  imageUrl    String?                @map("image_url")
  maxGuests   Int?                   @map("max_guests")
  startsAt    DateTime?              @map("starts_at")
  endsAt      DateTime?              @map("ends_at")
  version     Int                    @default(0)
  createdAt   DateTime               @default(now()) @map("created_at")
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tickets     Ticket[]
  ticketTypes TicketType[]
  temporaryScanners TemporaryScanner[]
  scans       Scan[]
  syncStates  SyncState[]
  debugData   DeviceEventDebugData[]

  @@unique([id, tenantId])
  @@index([tenantId, createdAt])
  @@map("events")
}

model Ticket {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  eventId   String   @map("event_id")
  guestId   String?  @map("guest_id")
  ticketTypeId String? @map("ticket_type_id")
  name      String
  status    String   @default("active")
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId, tenantId], references: [id, tenantId], onDelete: Cascade)
  guest     Guest?   @relation(fields: [guestId, tenantId], references: [id, tenantId], onDelete: SetNull)
  ticketType TicketType? @relation(fields: [ticketTypeId, tenantId], references: [id, tenantId], onDelete: SetNull)
  scans     Scan[]

  @@unique([id, tenantId])
  @@index([tenantId, eventId, createdAt])
  @@map("tickets")
}

model TemporaryScanner {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  eventId    String   @map("event_id")
  userId     String   @map("user_id")
  createdBy  String   @map("created_by")
  name       String
  loginToken String   @unique @map("login_token")
  isActive   Boolean  @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId, tenantId], references: [id, tenantId], onDelete: Cascade)
  user       User     @relation("TemporaryScannerUser", fields: [userId], references: [id], onDelete: Cascade)
  creator    User     @relation("TemporaryScannerCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([tenantId, eventId, createdAt])
  @@index([tenantId, userId])
  @@unique([eventId, userId])
  @@map("temporary_scanners")
}

model TicketType {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  eventId   String   @map("event_id")
  name      String
  price     Decimal  @db.Decimal(10, 2)
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tickets   Ticket[]

  @@unique([id, tenantId])
  @@index([eventId, tenantId])
  @@map("ticket_types")
}

model Scan {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  ticketId  String   @map("ticket_id")
  eventId   String   @map("event_id")
  deviceId  String   @map("device_id")
  userId    String   @map("user_id")
  dedupeKey String?  @map("dedupe_key")
  scannedAt DateTime @map("scanned_at")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket    Ticket   @relation(fields: [ticketId, tenantId], references: [id, tenantId], onDelete: Cascade)
  event     Event    @relation(fields: [eventId, tenantId], references: [id, tenantId], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([id, tenantId])
  @@unique([tenantId, dedupeKey])
  @@index([tenantId, eventId, createdAt])
  @@map("scans")
}

model DeviceEventDebugData {
  id        String   @id
  tenantId  String   @map("tenant_id")
  eventId   String   @map("event_id")
  deviceId  String   @map("device_id")
  userId    String   @map("user_id")
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@index([tenantId, eventId, createdAt])
  @@map("device_event_debug_data")
}

model SyncState {
  tenantId          String   @map("tenant_id")
  deviceId          String   @map("device_id")
  eventId           String   @map("event_id")
  lastTicketVersion Int      @default(0) @map("last_ticket_version")
  lastScanCursor    DateTime @default(now()) @map("last_scan_cursor")
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event             Event    @relation(fields: [eventId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([tenantId, deviceId, eventId])
  @@map("sync_state")
}

model Guest {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tickets   Ticket[]

  @@unique([id, tenantId])
  @@index([tenantId, name])
  @@map("guests")
}
